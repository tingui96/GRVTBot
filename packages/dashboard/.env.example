# GRVT Grid dashboard env
# Copy to .env.local and fill in.
#
# In dev, leave VITE_API_BASE_URL empty (or "/") so the Vite proxy
# in vite.config.ts handles routing to the backend.
# Override VITE_BACKEND_TARGET to point the proxy at a remote backend.

VITE_API_BASE_URL=
VITE_DASHBOARD_API_KEY=replace_me_64_chars
VITE_BACKEND_TARGET=http://localhost:3848
