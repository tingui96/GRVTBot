# GRVT API — Trading account
# Get these from your GRVT account UI: https://grvt.io
# The API SECRET is your EIP-712 signing private key. Treat it as a wallet key.
GRVT_API_KEY=
GRVT_API_SECRET=0x...
GRVT_TRADING_ACCOUNT_ID=
GRVT_TRADING_ADDRESS=0x...

# Optional: separate funding account (not required for trading)
GRVT_FUNDING_API_KEY=
GRVT_FUNDING_API_SECRET=
GRVT_FUNDING_WALLET_ADDRESS=

# Dashboard / API
DASHBOARD_PORT=3848
DASHBOARD_API_KEY=replace-with-32-char-random-string

# Prometheus /api/v2/metrics gate. Without this set, /metrics only
# answers requests originating from localhost (127.0.0.1 / ::1). To allow
# a remote Prometheus / Grafana Agent to scrape, set a long random token
# (min 16 chars) and configure the scraper to send
#   Authorization: Bearer <token>
# Leaving this blank is safe — it just keeps /metrics localhost-only.
METRICS_TOKEN=

# Logging
LOG_LEVEL=info
NODE_ENV=development

# Mock mode (development without touching real GRVT account)
# When MOCK_MODE=true, the bot serves fake data and never authenticates with GRVT
MOCK_MODE=false

# Dry run (real auth, simulated orders) — useful for smoke-testing in production
DRY_RUN=false

# SMTP (optional, for password reset emails — E.9). If unset, the reset
# URL is only logged at WARN level and must be delivered out-of-band.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# Public URL the dashboard is served from. Used to build absolute links
# inside password-reset emails. REQUIRED for /auth/forgot-password to
# emit a working reset link — if unset, the endpoint stays enumeration-
# safe (returns 200) but never sends a usable URL. Must be a full
# scheme+host with no trailing slash, e.g. https://grvt.example.com
APP_BASE_URL=
