# GRVT Grid — self-host environment.
#
# Copy this file to .env and fill in. NEVER commit .env to git.
# (It's covered by .gitignore.)
#
# ─── GRVT credentials ───────────────────────────────────────────────────
# Generate from your GRVT account UI: https://grvt.io
# IMPORTANT: register through the referral link the project shares with the
# community. Self-hosting via this repo requires you to use the referral link.
GRVT_API_KEY=
GRVT_API_SECRET=0x...
GRVT_TRADING_ACCOUNT_ID=
GRVT_TRADING_ADDRESS=0x...

# Optional: separate funding (vault) account credentials
GRVT_FUNDING_API_KEY=
GRVT_FUNDING_API_SECRET=
GRVT_FUNDING_WALLET_ADDRESS=

# ─── Dashboard ─────────────────────────────────────────────────────────
# Session signing key — REQUIRED, min 32 chars. Generate: openssl rand -base64 48
JWT_SECRET=

# Your email — this account becomes admin when you sign up in the dashboard.
ADMIN_EMAIL=

# 32+ char random hex. Generate with:  openssl rand -hex 32
DASHBOARD_API_KEY=

# Legacy basic auth for the v1 dashboard (still mounted at /).
# Remove these once you've migrated fully to the v2 dashboard at /dashboard/.
DASHBOARD_USER=admin
DASHBOARD_PASS=change-me

# Bind port on the host. With caddy, you can leave this and only expose 80/443.
BOT_PORT=3848

# ─── SMTP (optional, for password reset — E.9) ────────────────────────
# If left blank, password reset still works but the reset URL is logged
# at WARN level on the bot server — admin must deliver it out-of-band.
# Configure these to enable real email delivery.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# Public URL of the dashboard. Used to build absolute links inside emails
# (e.g. https://grvt-grid.example.com/dashboard/reset-password?token=...).
# Leave blank to derive from the request host (only correct if you do not
# sit behind a reverse proxy that rewrites the Host header).
APP_BASE_URL=

# ─── Notifier (optional) ───────────────────────────────────────────────
# Get TELEGRAM_BOT_TOKEN from @BotFather, then send any message to your bot
# and grab your chat id from
#   https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
NOTIFY_DRAWDOWN_PCT=15
NOTIFY_FILL_BATCH=5
DAILY_SUMMARY_HOUR_UTC=0

# ─── Logging ───────────────────────────────────────────────────────────
LOG_LEVEL=info
